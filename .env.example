# ZoneIQ Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Railway auto-injects this. For local dev:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/zoneiq_db
DATABASE_URL=

# Admin secret for /run-pipeline endpoint
ADMIN_SECRET=zoneiq2026

# Alert threshold - score jump in points to fire an alert
ALERT_THRESHOLD=15

# Google Trends rate limit delay in seconds
GOOGLE_TRENDS_DELAY_SECONDS=5
